{
  "openapi": "3.1.1",
  "info": {
    "title": "ECode.API | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7189"
    },
    {
      "url": "http://localhost:5099"
    }
  ],
  "paths": {
    "/api/Auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/QrCodes": {
      "post": {
        "tags": [
          "QrCodes"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQrRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQrRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQrRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/QrCodes/user/{userId}": {
      "get": {
        "tags": [
          "QrCodes"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/QrCodes/{uid}": {
      "delete": {
        "tags": [
          "QrCodes"
        ],
        "parameters": [
          {
            "name": "uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Scan": {
      "post": {
        "tags": [
          "Scan"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScanRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ScanRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ScanRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateQrRequest": {
        "required": [
          "uid",
          "creatorUserId",
          "subjectName",
          "subjectEmail",
          "subjectPhone",
          "categoryName",
          "customText",
          "payloadText"
        ],
        "type": "object",
        "properties": {
          "uid": {
            "type": "string"
          },
          "creatorUserId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "subjectName": {
            "type": [
              "null",
              "string"
            ]
          },
          "subjectEmail": {
            "type": [
              "null",
              "string"
            ]
          },
          "subjectPhone": {
            "type": [
              "null",
              "string"
            ]
          },
          "categoryName": {
            "type": "string"
          },
          "customText": {
            "type": [
              "null",
              "string"
            ]
          },
          "payloadText": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "contactType",
          "contactValue",
          "password"
        ],
        "type": "object",
        "properties": {
          "contactType": {
            "type": "string"
          },
          "contactValue": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "required": [
          "fullName",
          "contactType",
          "contactValue",
          "password"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string"
          },
          "contactType": {
            "type": "string"
          },
          "contactValue": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ScanRequest": {
        "required": [
          "rawContent",
          "scannedByUserId"
        ],
        "type": "object",
        "properties": {
          "rawContent": {
            "type": "string"
          },
          "scannedByUserId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int64"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "QrCodes"
    },
    {
      "name": "Scan"
    }
  ]
}